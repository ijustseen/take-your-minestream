{
  "schemaVersion": 1,
  "id": "take-your-stream-chat",
  "version": "${version}",
  "name": "Take Your Stream Chat",
  "description": "Display live chat from Twitch, YouTube, Kick, and TikTok in Minecraft — 3D billboards or HUD overlay. In-game settings: ] (default)",
  "authors": ["ijustseen"],
  "contact": {
    "homepage": "https://modrinth.com/mod/take-your-stream-chat",
    "sources": "https://github.com/ijustseen/take-your-minestream"
  },
  "license": "MIT",
  "icon": "assets/take-your-stream-chat/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["takeyourminestream.ijustseen.TakeYourMineStreamClient"],
    "modmenu": ["takeyourminestream.ijustseen.ModMenuIntegration"]
  },
  "mixins": [
    {
      "config": "take-your-stream-chat.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_min}",
    "minecraft": "${minecraft}",
    "java": ">=${java_min}",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*",
    "modmenu": "*"
  }
}
